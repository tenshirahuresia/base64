javascript:(async()=>{const t=await fetch("https://scratch.mit.edu/session/",{headers:{"X-Requested-With":"XMLHttpRequest"}});const j=await t.json();const token=j.user.token;navigator.clipboard.writeText(token);alert("x-tokenをコピーしました！\n\n次に.sb3を選んでください");const input=document.createElement("input");input.type="file";input.accept=".sb3";input.onchange=async e=>{const file=e.target.files[0];if(!file)return;const buf=await file.arrayBuffer();console.log("%c=== ここから下をコンソールに貼って実行（IDは自分の新規プロジェクトIDに変えて）===", "color:red;font-size:16px");console.log(`fetch("https://projects.scratch.mit.edu/", {method:"POST",headers:{"X-Token":"\( {token}"},body:new Uint8Array([ \){new Uint8Array(buf)}])}).then(r=>r.text()).then(console.log)`)};input.click()})()
